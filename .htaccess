Options -Indexes

# ── Security Headers ─────────────────────────────────────────
<IfModule mod_headers.c>
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
  Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://unpkg.com https://cdnjs.cloudflare.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://unpkg.com; font-src https://fonts.gstatic.com https://unpkg.com; img-src 'self' https://images.unsplash.com https://aphernzz.com https://*.tile.openstreetmap.org https://unpkg.com data:; connect-src 'self' https://formsubmit.co https://*.tile.openstreetmap.org; form-action 'self' https://formsubmit.co;"
  Header unset Server
  Header unset X-Powered-By
</IfModule>

# ── Limit request body size (2 MB) ──────────────────────────
LimitRequestBody 2097152

# ── Block sensitive files ────────────────────────────────────
<FilesMatch "(\.env|\.git|composer\.(json|lock)|package(-lock)?\.json|server\.js|seed\.js|auth\.js|\.sql|\.log|\.bak)$">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order Allow,Deny
    Deny from all
  </IfModule>
</FilesMatch>

# DirectoryIndex
DirectoryIndex index.html

# ── Rewrite: security + clean URLs ──────────────────────────
<IfModule mod_rewrite.c>
  RewriteEngine On

  # Block SQL injection / XSS probes in query string
  RewriteCond %{QUERY_STRING} (union.*select|select.*from|insert.*into|drop\s+table|<script|javascript:|vbscript:|onload=|onerror=|eval\() [NC]
  RewriteRule .* - [F,L]

  # Block path traversal
  RewriteCond %{REQUEST_URI} (\.\./|%2e%2e%2f|%252e%252e) [NC]
  RewriteRule .* - [F,L]

  # Block hidden files/dirs (except .well-known)
  RewriteRule (^|/)\.(?!well-known) - [F,L]

  # 301: /path/file.html → /path/file (SEO clean URLs)
  RewriteCond %{THE_REQUEST} \s(.+?)\.html[\s?] [NC]
  RewriteRule ^ %1 [R=301,NE,L]

  # Internal rewrite: serve .html for clean URLs
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME}.html -f
  RewriteRule ^ %{REQUEST_URI}.html [L]
</IfModule>

# ── Cache static assets ──────────────────────────────────────
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType image/png "access plus 6 months"
  ExpiresByType image/jpeg "access plus 6 months"
  ExpiresByType image/svg+xml "access plus 6 months"
  ExpiresByType image/x-icon "access plus 1 year"
  ExpiresByType application/xml "access plus 1 day"
</IfModule>
