# ── CRM Aphernzz — Variables de entorno ──────────────────────
# Copia este archivo como .env y rellena con tus valores reales.
# NUNCA subas .env a git.

# Base de datos MySQL (cPanel → Bases de datos MySQL)
CRM_DB_HOST=localhost
CRM_DB_USER=cpanel_usuario_db
CRM_DB_PASS=contraseña_muy_segura
CRM_DB_NAME=cpanel_nombre_db

# JWT Secret — genera uno nuevo con:  openssl rand -hex 32
CRM_JWT_SECRET=reemplaza_con_64_caracteres_aleatorios

# (Solo si usas proxy.php con Node.js en Railway/Render)
PROXY_TARGET=https://tu-app.up.railway.app

# (Solo para server.js Node.js)
JWT_SECRET=mismo_valor_que_CRM_JWT_SECRET
DB_HOST=localhost
DB_USER=cpanel_usuario_db
DB_PASSWORD=contraseña_muy_segura
DB_NAME=cpanel_nombre_db
CORS_ORIGIN=https://aphernzz.com
ADMIN_INIT_PASSWORD=contraseña_admin_inicial_muy_segura
