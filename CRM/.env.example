# ── Base de datos ──────────────────────────────────────────────────────────────
# En cPanel: usa el usuario/DB creados en "MySQL Databases"
# El nombre real será  cpanelusr_crm_aphernzz  (cPanel agrega tu username)
DB_HOST=localhost
DB_PORT=3306
DB_USER=cpanelusr_dbuser
DB_PASSWORD=tu_password_mysql
DB_NAME=cpanelusr_crm_aphernzz

# ── Servidor ───────────────────────────────────────────────────────────────────
# En cPanel Node.js Selector el puerto lo asigna cPanel automáticamente.
# NO cambies PORT manualmente — cPanel lo inyecta como variable de entorno.
PORT=3000

# ── CORS ───────────────────────────────────────────────────────────────────────
# Pon el dominio exacto donde estará el HTML (sin barra final)
CORS_ORIGIN=https://aphernzz.com

# ── JWT ────────────────────────────────────────────────────────────────────────
# Genera uno nuevo con: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=reemplaza_con_una_clave_aleatoria_de_96_caracteres_hex
JWT_EXPIRES=8h
